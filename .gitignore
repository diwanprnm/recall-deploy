# ────────────────────────────────────────────
# .gitignore for recall-deploy (parent repo)
# ────────────────────────────────────────────

# Environment secrets
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Editor / IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Docker volumes (if any are bind-mounted)
volumes/
data/

# Backup files
*.bak
*.backup
*.old
