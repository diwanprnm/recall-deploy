# ──── Env file for local dev (jangan pakai ini di production!) ────

# ──── Frontend: needed at BUILD time for Next.js (NEXT_PUBLIC_*) ────
# Get these from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ──── Backend: needed at RUNTIME by FastAPI ────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ──── AI Service (9router – OpenAI-compatible) ────
OPENAI_API_KEY=your-9router-api-key
OPENAI_BASE_URL=https://api.9router.com/v1
AI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ──── Production secrets for local docker (override outside dev) ────
# Leave empty for local dev (we spin up mock data)
SENTRY_DSN=
